# Copy to .env and fill in. These are BOOTSTRAP values only — after running
# scripts/seed_credentials.py they live encrypted in the vault and can be
# removed from this file.

# OpenAI ($200 credit): cloud baseline, tool generation, auto-fallback
OPENAI_API_KEY=

# Firebase: path to the service-account JSON you download from
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=

# Telegram: token from @BotFather
TELEGRAM_BOT_TOKEN=

# Model routing: local | cloud | auto  (auto = local first, cloud on failure)
MODEL_MODE=auto
LOCAL_MODEL=qwen3:8b
